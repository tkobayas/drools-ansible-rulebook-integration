[
    {
        "RuleSet": {
            "name": "once_within 1k events",
            "hosts": [
                "all"
            ],
            "sources": [
                {
                    "EventSource": {
                        "name": "generic",
                        "source_name": "generic",
                        "source_args": {
                            "repeat_count": 1000,
                            "payload": [
                                {
                                    "i": 1,
                                    "data": ""
                                }
                            ]
                        },
                        "source_filters": []
                    }
                }
            ],
            "rules": [
                {
                    "Rule": {
                        "name": "r1",
                        "condition": {
                            "AllCondition": [
                                {
                                    "EqualsExpression": {
                                        "lhs": {
                                            "Event": "i"
                                        },
                                        "rhs": {
                                            "Integer": 1
                                        }
                                    }
                                }
                            ]
                        },
                        "action": {
                            "Action": {
                                "action": "debug",
                                "action_args": {}
                            }
                        },
                        "enabled": true,
                        "throttle": {
                            "group_by_attributes": [
                                "event.meta.uuid"
                            ],
                            "once_within": "60 seconds"
                        }
                    }
                }
            ]
        }
    }
]